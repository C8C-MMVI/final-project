                "raw": "{\n  \"name\": \"TechFix Manila\",\n  \"description\": \"Expert laptop and phone repairs in the metro.\",\n  \"address\": \"123 Rizal Ave, Quezon City\",\n  \"phone\": \"09171234567\",\n  \"email\": \"techfix@example.com\"\n}"
