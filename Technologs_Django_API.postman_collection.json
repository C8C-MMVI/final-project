              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                    "pm.test('Has owner field', () => {",
                    "  pm.expect(pm.response.json()).to.have.property('owner');",
                    "});"
                  ]
                }
              }
            ],
            "request": {
              "method": "GET",
              "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
              "url": { "raw": "{{base_url}}/api/shop/shops/{{shop_id}}/", "host": ["{{base_url}}"], "path": ["api","shop","shops","{{shop_id}}",""] }
            }
